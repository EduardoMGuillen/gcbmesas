// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MESERO
  CAJERO
  TAQUILLA
  COCINA
  BAR
  /// Cliente externo: solo módulo Entradas y eventos asignados por admin
  CLIENTE_TICKETERA
}

enum AccountStatus {
  OPEN
  CLOSED
}

enum LogAction {
  ACCOUNT_OPENED
  ACCOUNT_CLOSED
  ORDER_CREATED
  ORDER_CANCELLED
  ORDER_REJECTED
  PRODUCT_ADDED
  PRODUCT_UPDATED
  PRODUCT_ACTIVATED
  PRODUCT_DEACTIVATED
  PRODUCT_DELETED
  TABLE_CREATED
  TABLE_UPDATED
  TABLE_DELETED
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  LOGIN
  LOGOUT
  EVENT_CREATED
  EVENT_UPDATED
  ENTRY_SOLD
  ENTRY_USED
  PAYMENT_REFUNDED
  ATTENDANCE_MARK
  /// Auditoría CyberSource (3DS, adquirente) por transacción — ver details.type
  CYBERSOURCE_PAYMENT_AUDIT
}

enum AttendanceMarkType {
  IN
  OUT
}

enum EntryStatus {
  ACTIVE
  USED
  CANCELLED
}

/// Cola cocina/bar tras aceptación en caja
enum OrderPrepStatus {
  NONE
  QUEUED
  PREPARING
  READY
}

/// Destino de comandas por categoría de producto (configuración admin)
enum PrepCategoryDestination {
  COCINA
  BAR
}

model AppSettings {
  id        Int      @id @default(1)
  updatedAt DateTime @updatedAt

  clientSelfOrderingEnabled Boolean @default(true)

  invoiceLegalName   String?
  invoiceTradeName   String?
  invoiceRtn         String?
  invoiceAddress     String? @db.Text
  invoicePhone       String?
  invoiceEmail       String?
  invoiceCaiBlock    String? @db.Text
  invoiceFooterNote  String? @db.Text
  /// Porcentaje ISV (ej. 15). null = usar 15 en UI
  invoiceIsvPercent  Decimal? @db.Decimal(5, 2)

  @@map("app_settings")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  name      String?
  password  String
  role      UserRole @default(MESERO)
  /// Solo rol ADMIN en práctica: recibir push al venderse entradas (taquilla u online).
  notifyEntrySales Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders            Order[] @relation("OrderCreatedByUser")
  logs              Log[]
  openedAccounts    Account[]
  pushSubscriptions PushSubscription[]
  createdEvents     Event[]
  createdEntries    Entry[]
  attendanceMarks   AttendanceMark[]
  /// Meseros que este cajero sigue para recibir notificaciones de pedidos
  cajeroWatchesMeseros CajeroMeseroWatch[] @relation("CajeroWatchesMesero")
  /// Cajeros que siguen a este mesero
  meseroWatchedByCajeros CajeroMeseroWatch[] @relation("MeseroWatchedByCajeros")
  prepCategories         UserPrepCategory[]
  /// Cajeros cuyas comandas de bar ve este usuario (rol BAR)
  barCajeroWatches       BarCajeroWatch[] @relation("BarWatchesCajero")
  /// Usuarios BAR que reciben comandas de este cajero
  cajeroWatchedByBars    BarCajeroWatch[] @relation("CajeroWatchedByBar")
  /// Pedidos aceptados en caja por este usuario (servedByUserId)
  ordersAcceptedAsCashier Order[] @relation("OrderServedByCashier")
  /// Eventos de ticketera visibles para este usuario (rol CLIENTE_TICKETERA)
  ticketeraEventAssignments UserEventAssignment[]

  @@map("users")
}

/// Cajeros de los que el bar quiere ver comandas (aceptación en caja)
model BarCajeroWatch {
  id        String   @id @default(cuid())
  barUserId String
  cajeroId  String
  createdAt DateTime @default(now())

  barUser User @relation("BarWatchesCajero", fields: [barUserId], references: [id], onDelete: Cascade)
  cajero  User @relation("CajeroWatchedByBar", fields: [cajeroId], references: [id], onDelete: Cascade)

  @@unique([barUserId, cajeroId])
  @@index([barUserId])
  @@index([cajeroId])
  @@map("bar_cajero_watches")
}

/// Categoría de producto → cocina o bar (si hay filas, se usa enrutado global en comandas)
model PrepCategoryStation {
  category String @id
  station  PrepCategoryDestination

  @@map("prep_category_stations")
}

/// Eventos que un cliente ticketera puede gestionar (ventas / historial)
model UserEventAssignment {
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([userId, eventId])
  @@index([eventId])
  @@map("user_event_assignments")
}

/// Cajero elige qué meseros le notifican pedidos (misma lógica que el filtro del panel)
model CajeroMeseroWatch {
  id        String   @id @default(cuid())
  cajeroId  String
  meseroId  String
  createdAt DateTime @default(now())

  cajero User @relation("CajeroWatchesMesero", fields: [cajeroId], references: [id], onDelete: Cascade)
  mesero User @relation("MeseroWatchedByCajeros", fields: [meseroId], references: [id], onDelete: Cascade)

  @@unique([cajeroId, meseroId])
  @@index([cajeroId])
  @@index([meseroId])
  @@map("cajero_mesero_watches")
}

/// Categorías de producto que este usuario de cocina/bar quiere ver en comandas
model UserPrepCategory {
  id        String   @id @default(cuid())
  userId    String
  /// Valor de Product.category o "__NONE__" para productos sin categoría
  category  String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
  @@map("user_prep_categories")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  platform  String   @default("web")
  p256dh    String?
  auth      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model Table {
  id        String   @id @default(cuid())
  name      String
  zone      String?
  qrUrl     String?  @unique
  shortCode String   @unique @map("shortcode")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  logs     Log[]

  @@map("tables")
}

model Account {
  id              String        @id @default(cuid())
  tableId         String
  initialBalance  Decimal       @db.Decimal(10, 2)
  currentBalance  Decimal       @db.Decimal(10, 2)
  status          AccountStatus @default(OPEN)
  createdAt       DateTime      @default(now())
  closedAt        DateTime?
  openedByUserId  String?
  clientName      String?

  table      Table   @relation(fields: [tableId], references: [id], onDelete: Cascade)
  openedBy   User?   @relation(fields: [openedByUserId], references: [id], onDelete: SetNull)
  orders     Order[]

  @@index([status, createdAt])
  @@index([tableId, status])
  @@map("accounts")
}

model Product {
  id           String   @id @default(cuid())
  name         String
  price        Decimal  @db.Decimal(10, 2)
  category     String?
  emoji        String?
  isActive     Boolean  @default(true)
  /// Si false, al aceptar en caja no entra a cola cocina/bar
  requiresPrep Boolean  @default(true)
  /// Si true, línea exenta de ISV en factura impresa
  isTaxExempt  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]

  @@map("products")
}

model Order {
  id         String          @id @default(cuid())
  accountId  String
  productId  String
  userId     String
  /// Usuario que aceptó el pedido en caja (sirve para filtrar comandas en bar)
  servedByUserId String?
  price      Decimal         @db.Decimal(10, 2)
  quantity   Int             @default(1)
  served     Boolean         @default(false)
  rejected   Boolean         @default(false)
  prepStatus OrderPrepStatus @default(NONE)
  createdAt  DateTime        @default(now())

  account  Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  product  Product @relation(fields: [productId], references: [id])
  user     User    @relation("OrderCreatedByUser", fields: [userId], references: [id])
  servedBy User?   @relation("OrderServedByCashier", fields: [servedByUserId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([userId])
  @@index([servedByUserId])
  @@index([createdAt])
  @@index([served, rejected, createdAt])
  @@index([accountId, rejected])
  @@index([prepStatus, createdAt])
  @@map("orders")
}

model Log {
  id        String    @id @default(cuid())
  userId    String?
  tableId   String?
  action    LogAction
  details   Json?
  createdAt DateTime  @default(now())

  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  table Table? @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tableId])
  @@index([action])
  @@index([createdAt])
  @@map("logs")
}

/// Rechazos / fallos del flujo de pago online (entradas). Solo auditoría; no afecta cobros.
model OnlinePaymentRejection {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  /// Origen: confirm-payment, create-payment, payer-auth, payer-auth-result
  source           String
  httpStatus       Int
  /// Clave para filtro (validacion_datos, banco_rechazo, tres_ds, …)
  reasonCategory   String
  friendlyMessage  String   @db.Text
  rawMessage       String   @db.Text
  eventId          String?
  paymentReference String?
  clientEmail      String?

  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([reasonCategory])
  @@index([eventId])
  @@index([paymentReference])
  @@map("online_payment_rejections")
}

model Event {
  id              String   @id @default(cuid())
  name            String
  date            DateTime
  description     String?
  coverImage      String?
  coverPrice      Decimal  @db.Decimal(10, 2)
  paypalPrice     Decimal? @db.Decimal(10, 2)
  /// Máximo de entradas vendibles (suma de numberOfEntries, excl. canceladas). null = sin límite.
  maxEntries      Int?
  isActive        Boolean  @default(true)
  /// Listado público La Gran Casa Blanca (/eventos, landing).
  publishOnLcb       Boolean  @default(true)
  /// Listado público CBTickets (/cbtickets).
  publishOnCbtickets Boolean  @default(false)
  venueName          String?
  venueAddress       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdByUserId String?

  createdBy User?   @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  entries   Entry[]
  ticketeraAssignments UserEventAssignment[]
  onlinePaymentRejections OnlinePaymentRejection[]

  @@index([isActive])
  @@index([date])
  @@index([publishOnLcb])
  @@index([publishOnCbtickets])
  @@map("events")
}

model Entry {
  id              String      @id @default(cuid())
  eventId         String
  clientName      String
  clientEmail     String
  clientPhone     String?
  numberOfEntries Int
  totalPrice      Decimal     @db.Decimal(10, 2)
  qrToken         String      @unique
  status          EntryStatus @default(ACTIVE)
  emailSent       Boolean     @default(false)
  whatsappSent    Boolean     @default(false)
  createdAt       DateTime    @default(now())
  createdByUserId String?

  event     Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdBy User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@index([qrToken])
  @@index([status])
  @@index([createdAt])
  @@map("entries")
}

model AttendanceMark {
  id             String             @id @default(cuid())
  userId         String
  role           UserRole
  type           AttendanceMarkType
  markedAt       DateTime           @default(now())
  latitude       Float
  longitude      Float
  accuracyMeters Float
  selfieUrl      String
  source         String             @default("web")
  userAgent      String?
  notes          String?
  createdAt      DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, markedAt])
  @@index([role, markedAt])
  @@index([type, markedAt])
  @@index([createdAt])
  @@map("attendance_marks")
}

model AttendanceSettings {
  id                 Int      @id
  referenceLatitude  Float
  referenceLongitude Float
  radiusMeters       Int      @default(100)
  maxAccuracyMeters  Int      @default(200)
  isActive           Boolean  @default(true)
  updatedByUserId    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("attendance_settings")
}
